      <aliases enabled='yes' />
      <column caption='Profit Margin' datatype='real' default-format='p0.00%' name='[Calculation_0459887734415360]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([sales]) = 0 THEN&#13;&#10;    0&#13;&#10;ELSE&#13;&#10;    SUM([profit]) / SUM([sales])&#13;&#10;END' />
      </column>
      <column caption='Cost' datatype='real' name='[Calculation_0459887736832001]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[sales] - [profit]' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_0459887737049090]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales]) / COUNTD([order_id])' />
      </column>
      <column caption='Return Rate' datatype='real' name='[Calculation_0459887737286659]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([return_flag]) / COUNT([order_id])' />
      </column>
      <column caption='Shipping Delay Bucket' datatype='string' name='[Calculation_0459887737937924]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [delivery_days] &lt;= 2 THEN&#13;&#10;    &quot;Fast (0-2 Days)&quot;&#13;&#10;ELSEIF [delivery_days] &lt;= 5 THEN&#13;&#10;    &quot;Normal (3-5 Days)&quot;&#13;&#10;ELSE&#13;&#10;    &quot;Delayed (6+ Days)&quot;&#13;&#10;END' />
      </column>
      <column caption='Returned Orders' datatype='string' name='[Calculation_0459887738290181]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [return_flag] = 1 THEN&#13;&#10;    &quot;Returned&quot;&#13;&#10;ELSE&#13;&#10;    &quot;Not Returned&quot;&#13;&#10;END' />
      </column>
